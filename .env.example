# Discord & App Credentials
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback
DISCORD_GUILD_ID=your_main_guild_id_here

# JWT
JWT_SECRET=change_this_to_a_very_long_random_string_in_production

# URLs
BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vn_trpg?retryWrites=true&w=majority

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=vn-trpg-assets
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Bot Internal Auth (used by bot to authenticate with backend)
BOT_SECRET=change_this_to_a_random_string

# Node Environment
NODE_ENV=development
PORT=4000
